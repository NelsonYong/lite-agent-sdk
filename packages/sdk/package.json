{
  "name": "@lite-agent/sdk",
  "version": "0.11.0",
  "description": "Batteries-included agent SDK over @lite-agent/core: tools, skills, system prompt, and query()/createLiteAgent().",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "agent-sdk",
    "tool-use"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NelsonYong/lite-agent-sdk.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lite-agent/core": "workspace:*",
    "gray-matter": "^4.0.3",
    "p-limit": "^7.3.0",
    "proper-lockfile": "^4.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.3.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.0"
  }
}
