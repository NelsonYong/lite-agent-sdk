{
  "name": "@lite-agent/provider-anthropic",
  "version": "0.0.0",
  "description": "Anthropic Messages API ModelProvider for @lite-agent/core.",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "anthropic",
    "claude",
    "provider"
  ],
  "repository": {
    "type": "git",
    "url": "git+http://192.168.110.96:30080/yangjie/lite-agent.git",
    "directory": "packages/provider-anthropic"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --tsconfig tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@lite-agent/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.0"
  }
