# Copy to .env in this directory (examples/cli/.env).
LITE_AGENT_MODEL_ID=claude-sonnet-4-6
LITE_AGENT_MODEL_API_KEY=sk-...
LITE_AGENT_BASE_URL=https://api.anthropic.com
